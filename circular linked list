#include <stdio.h>
#include <stdlib.h>

struct node {
    int data;
    struct node* next;
};

struct node* last = NULL;

void insert(int value) {
    struct node* newNode = (struct node*)malloc(sizeof(struct node));
    newNode->data = value;

    if(last == NULL) {
        last = newNode;
        last->next = last;
    } else {
        newNode->next = last->next;
        last->next = newNode;
        last = newNode;
    }
}

void display() {
    if(last == NULL) return;
    struct node* temp = last->next;
    do {
        printf("%d ", temp->data);
        temp = temp->next;
    } while(temp != last->next);
}

int main() {
    insert(1);
    insert(2);
    insert(3);
    display();
}
