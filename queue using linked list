#include <stdio.h>
#include <stdlib.h>

struct node {
    int data;
    struct node* next;
};

struct node *front=NULL, *rear=NULL;

void enqueue(int value){
    struct node* newNode = malloc(sizeof(struct node));
    newNode->data=value;
    newNode->next=NULL;

    if(rear==NULL)
        front=rear=newNode;
    else {
        rear->next=newNode;
        rear=newNode;
    }
}

void dequeue(){
    if(front==NULL) return;
    struct node* temp=front;
    front=front->next;
    free(temp);
}

void display(){
    struct node* temp=front;
    while(temp){
        printf("%d ",temp->data);
        temp=temp->next;
    }
}

int main(){
    enqueue(10);
    enqueue(20);
    dequeue();
    display();
}
