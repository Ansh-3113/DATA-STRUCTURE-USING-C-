#include <stdio.h>

int main() {
    int A[10][10], B[10][10], result[10][10];
    int rows, cols, i, j, k, choice;

    printf("Enter number of rows and columns: ");
    scanf("%d %d", &rows, &cols);

    printf("\nEnter elements of Matrix A:\n");
    for(i = 0; i < rows; i++)
        for(j = 0; j < cols; j++)
            scanf("%d", &A[i][j]);

    printf("\nEnter elements of Matrix B:\n");
    for(i = 0; i < rows; i++)
        for(j = 0; j < cols; j++)
            scanf("%d", &B[i][j]);

    printf("\nChoose Operation:\n");
    printf("1. Addition\n");
    printf("2. Subtraction\n");
    printf("3. Multiplication\n");
    printf("4. Transpose of Matrix A\n");
    printf("Enter choice: ");
    scanf("%d", &choice);

    switch(choice) {

        case 1: Addition
            for(i = 0; i < rows; i++)
                for(j = 0; j < cols; j++)
                    result[i][j] = A[i][j] + B[i][j];

            printf("\nSum of matrices:\n");
            for(i = 0; i < rows; i++) {
                for(j = 0; j < cols; j++)
                    printf("%d ", result[i][j]);
                printf("\n");
            }
            break;

        case 2: Subtraction
            for(i = 0; i < rows; i++)
                for(j = 0; j < cols; j++)
                    result[i][j] = A[i][j] - B[i][j];

            printf("\nSubtraction of matrices:\n");
            for(i = 0; i < rows; i++) {
                for(j = 0; j < cols; j++)
                    printf("%d ", result[i][j]);
                printf("\n");
            }
            break;

        case 3: Multiplication
            for(i = 0; i < rows; i++)
                for(j = 0; j < cols; j++) {
                    result[i][j] = 0;
                    for(k = 0; k < cols; k++)
                        result[i][j] += A[i][k] * B[k][j];
                }

            printf("\nProduct of matrices:\n");
            for(i = 0; i < rows; i++) {
                for(j = 0; j < cols; j++)
                    printf("%d ", result[i][j]);
                printf("\n");
            }
            break;

        case 4: Transpose
            printf("\nTranspose of Matrix A:\n");
            for(i = 0; i < cols; i++) {
                for(j = 0; j < rows; j++)
                    printf("%d ", A[j][i]);
                printf("\n");
            }
            break;

        default:
            printf("Invalid choice!");
    }

    return 0;
}
